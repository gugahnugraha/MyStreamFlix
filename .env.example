
# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# TMDB_API_KEY: Optional, enables live movie, TV series, and cast suggestions.
# Get a v3 API key from https://www.themoviedb.org/settings/api
TMDB_API_KEY="MY_TMDB_API_KEY"

# DATABASE_URL: Set your PostgreSQL, Supabase or MongoDB connection URI here.
# By default, this placeholder is used to run the application in zero-config in-memory fallback.
# Replace this with your actual database connection URL when ready to deploy or persist data.
DATABASE_URL="postgresql://placeholder:placeholder@localhost:5432/placeholder"

# SESSION_SECRET: A long random string used to cryptographically sign session cookies (HMAC SHA-256).
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# If omitted, a built-in default key is used (acceptable for local development only).
SESSION_SECRET="MY_SESSION_SECRET"


# ==========================================
# STRIPE PAYMENT INTEGRATION (USD ONLY)
# ==========================================
# Replace with keys from your Stripe Dashboard (https://dashboard.stripe.com)
# If left empty or skipped, the system will automatically run in Sandbox Mode (Local Simulation).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_placeholder"
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"

# Stripe Price IDs (Create Products in Stripe with recurring monthly USD billing)
# Example pricing: VIP = $2.99/mo, Premium = $5.99/mo, Ultra = $8.99/mo
STRIPE_PRICE_ID_VIP="price_placeholder_vip"
STRIPE_PRICE_ID_PREMIUM="price_placeholder_premium"
STRIPE_PRICE_ID_ULTRA="price_placeholder_ultra"

# ==========================================
# PAYPAL PAYMENT INTEGRATION (USD ONLY)
# ==========================================
# Replace with credentials from PayPal Developer Portal (https://developer.paypal.com)
# If left empty or skipped, the PayPal payment option will not be activated.
PAYPAL_CLIENT_ID="paypal_client_id_placeholder"
PAYPAL_CLIENT_SECRET="paypal_secret_placeholder"
PAYPAL_MODE="sandbox" # Set to "live" for production environments

# PayPal Billing Plan IDs (Create Subscription Plans in your PayPal Business dashboard)
PAYPAL_PLAN_ID_VIP="p-placeholder-vip"
PAYPAL_PLAN_ID_PREMIUM="p-placeholder-premium"
PAYPAL_PLAN_ID_ULTRA="p-placeholder-ultra"
